from Pessoa import Pessoa
from Aluno import Aluno

pessoa = Pessoa("Luan", 20)
aluno = Aluno("Josias", 46, "232323-23")

print("--- Dados da Pessoa ---")
print(f"{pessoa.apresentar()}\n")

print("--- Dados do Aluno ---")
print(f"{aluno.apresentar_aluno()}\n")

print(isinstance(aluno, Pessoa))
print(isinstance(aluno, Pessoa))
print(isinstance(pessoa, Aluno))

print("\n")

print(issubclass(Aluno, Pessoa)) 
print(issubclass(Pessoa, Aluno))  
print(f"{issubclass(Aluno, Aluno)}\n")